Co0r3xRf:=name=Kontaktformularen:Contact form;#type=container;template=ZTISa5lu;description=Über dieses Formular können Sie uns eine Nachricht zukommen lassen.en:You can send us a message using this form.;confirmation=Vielen Dank für Ihre Nachricht.en:Thank you for your message.;email=info@example.com;captcha=1
VJ6UJHyG:=name=Betreffen:Subject;#type=checkbox;description=Ich wünsche nähere Informationen zu:en:I wish to receive further information about:;option=+Produkt A[chr10]Produkt B[chr10]Dienstleistung C[chr10]Dienstleistung D[chr10]Sonstigesen:+Product A[chr10]Product B[chr10]Service C[chr10]Service D[chr10]Other;column=2
ptuyiYHP:=name=Ihre Mitteilung an unsen:Your message to us;#type=textarea;width=0;height=0;required=1
75bO6V6P:=name=Organisationen:Organization;#type=text;width=0;length=200
mtVGTSbz:=name=Nameen:Name;#type=text;width=0;length=200;match=/^[chr91][chr92]p{L}[chr92]p{P}[chr92]p{Zs}]*$/u;required=1
6zxX7DLy:=name=Telefonen:Phone;#type=text;width=0;length=200;match=/^[chr91] [chr92]/[chr92]([chr92])0-9[chr92]+[chr92]-]*$/;required=1
qKsVlAMW:=name=E-Mail-Adresseen:E-mail address;#type=text;description=Eine Kopie Ihrer Anfrage wird an die angegebene E-Mail-Adresse gesendet.en:A copy of your inquiry will be sent to the specified e-mail address.;width=0;length=200;match=/^.+@.+[chr92]..+$/;required=1;confirm=1
Plrr4kCu:=name=Datenschutzen:Data privacy;#type=checkbox;description=Ich habe die %%data_privacy_statement%% zur Kenntnis genommen und bin damit einverstanden, dass die von mir angegebenen Daten elektronisch erhoben und gespeichert werden. Meine Daten werden dabei streng zweckgebunden zur Bearbeitung und Beantwortung meiner Anfrage genutzt.en:I have read the %%data_privacy_statement%% and agree that the data I provide will be collected and stored electronically. My data is strictly used for the specified purpose of processing and answering my request.;option=Bestätigten:Confirmed;column=1;required=1
dW527dtI:=#type=/container
